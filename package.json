{
  "name": "sdb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node scripts/prerender.mjs",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "npm run test:a11y",
    "test:a11y": "npm run build && node scripts/a11y-check.mjs",
    "accessibility": "npm run test:a11y",
    "lighthouse:a11y": "npm run build && node scripts/lighthouse-a11y.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.6",
    "@mui/material": "^6.1.6",
    "dompurify": "^3.4.8",
    "isomorphic-dompurify": "^3.16.0",
    "marked": "^15.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "lighthouse": "^13.3.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.4.1",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": ">=20"
  }
}
